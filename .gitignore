# ------------------------------------------------------------------------------
# Compiled Binaries & Build Artifacts
# ------------------------------------------------------------------------------
# C/C++
*.o
*.obj
*.exe
*.dll
*.so
*.dylib
*.out
*.app
*.i*86
*.x86_64
*.hex
*.bin
*.su
*.idb
*.pdb
.vs/
Debug/
Release/
x64/
x86/
build/
out/
.clangd/
.cache/

# C#
bin/
obj/
*.user
*.suo
*.userosscache
*.sln.docstates

# Java
*.class
*.jar
*.war
*.ear
*.nar
.project
.classpath
.settings/
target/

# Rust
**/*.rs.bk

# Go
*.exe~
*.test
/vendor/

# Web Development (HTML, CSS, JS, TS, Node)
node_modules/
dist/
.parcel-cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
.stylelintcache

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
env/
venv/
.venv/
pip-log.txt

# ------------------------------------------------------------------------------
# Competitive Programming Specific
# ------------------------------------------------------------------------------
input.txt
output.txt
error.txt
*.in
*.ans
temp/
test_runs/

# ------------------------------------------------------------------------------
# IDEs and Editors
# ------------------------------------------------------------------------------
.idea/
*.swp
*.swo
*~
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

